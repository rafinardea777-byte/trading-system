# =================================================================
# Trading System - Environment Variables
# העתק את הקובץ הזה ל-.env ומלא את הערכים האמיתיים
# שים לב: לעולם אל תעלה את .env ל-git!
# =================================================================

# --- Application ---
APP_ENV=development            # development | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
TIMEZONE=Asia/Jerusalem

# --- Database ---
DATABASE_URL=sqlite:///./data/trading.db

# --- Web / API ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Security (חובה ב-public_mode) ---
PUBLIC_MODE=false                          # true בפריסה ציבורית
ADMIN_API_KEY=                             # מפתח חזק - לפעולות admin (POST /scan/*)
RATE_LIMIT_PER_MINUTE=60                   # מקסימום בקשות לדקה לכל IP
CORS_ORIGINS=*                             # ב-production: https://yourdomain.com

# --- Scheduling (cron-like or interval in minutes) ---
NEWS_SCAN_INTERVAL_HOURS=24
MARKET_SCAN_INTERVAL_MINUTES=60
ENABLE_SCHEDULER=true

# --- Telegram Alerts ---
# צור בוט ב-@BotFather וקבל טוקן
# קבל chat_id ע"י שליחת הודעה לבוט והרצת:
#   curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ENABLE_TELEGRAM_ALERTS=false

# --- News Scanner: X (Twitter) API ---
# https://developer.x.com/  (Basic Tier $100/חודש לחיפוש)
X_BEARER_TOKEN=

# --- News Scanner: OpenAI (לסיכום ותרגום בעברית) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Market Scanner ---
SCAN_MIN_PRICE=1.0
SCAN_MAX_PRICE=500.0
SCAN_MIN_VOLUME=500000
VOLUME_SPIKE_RATIO=1.5
RSI_PERIOD=14
RSI_MIN=45
RSI_MAX=75
MA_FAST=20
MA_SLOW=50

# --- Risk Management (paper trading defaults) ---
POSITION_SIZE_USD=5000
MAX_OPEN_POSITIONS=5
STOP_LOSS_PCT=0.04
TARGET_1_PCT=0.08
TARGET_2_PCT=0.20

# --- Trading Mode ---
# paper = רק סימולציה (ברירת מחדל הבטוחה)
# live  = מסחר אמיתי (לא ממומש עדיין)
TRADING_MODE=paper
